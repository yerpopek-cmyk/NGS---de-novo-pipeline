# prepare workdir and switch there
mkdir day4
cd day4

# start SPAdes assembly (Illumina only), approx. 18 mins
spades.py -1 /home/prep00/data/illumina_R1.fq -2 /home/prep00/data/illumina_R2.fq --disable-gzip-output -t 5 -o assembly_spades_i

# start SPAdes assembly (Hybrid), approx. 15 mins
spades.py -1 /home/prep00/data/illumina_R1.fq -2 /home/prep00/data/illumina_R2.fq --nanopore /home/prep00/data/nanopore.fq --disable-gzip-output -t 5 -o assembly_spades_h

# filter long scaffolds only, not to overcrowd the picture
mkdir spades_vs_spades
seqtk seq -L 10000 assembly_spades_h/scaffolds.fasta > spades_vs_spades/scaffolds.hybrid.fasta
seqtk seq -L 10000 assembly_spades_i/scaffolds.fasta > spades_vs_spades/scaffolds.illumina.fasta

# go to folder and compare hybrid vs illumina-only
cd spades_vs_spades
# run Sibelia synteny-block search tool
Sibelia -s fine -o sibelia_out scaffolds.hybrid.fasta scaffolds.illumina.fasta
# visualize Sibelia output with Circos plot
circos --conf sibelia_out/circos/circos.conf

# go back to main day4 directory
cd ..

# scaffold illumina-only assembly using long reads
mkdir scaffolding
cd scaffolding

# create sym-links (shortcuts) for files
ln -s /home/prep00/data/nanopore.fq .
ln -s ../spades_vs_spades/scaffolds.illumina.fasta scaffolds.fa

# run LongStitch scaffolder
longstitch run draft=scaffolds reads=nanopore G=5000000 t=6 gap_fill=True rounds=3 longmap=ont k_ntLink=24 w=400

# compare hybrid assembly with the newly scaffolded assembly
Sibelia -s fine -o sibelia_out ../spades_vs_spades/scaffolds.hybrid.fasta scaffolds.k24.w400.tigmint-ntLink.longstitch-scaffolds.fa
circos --conf sibelia_out/circos/circos.conf

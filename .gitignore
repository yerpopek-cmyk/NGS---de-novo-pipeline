# =============================================================================
# .gitignore — NGS de novo assembly pipeline
# =============================================================================

# Raw sequencing data
*.fastq
*.fq
*.fastq.gz
*.fq.gz
*.sra

# Alignments
*.bam
*.bam.bai
*.sam
*.cram
*.crai

# BWA index files
*.bwt
*.pac
*.sa
*.amb
*.ann

# Compressed assemblies / references
*.fasta.gz
*.fa.gz

# Generated data and outputs
data/raw/
data/db/
data/reference/
results/

# SPAdes / assembler intermediates
K*/
corrected/
misc/
pipeline_state/

# Temporary / log files
*.tmp
*.log
tmp/
temp/

# Python / conda / caches
__pycache__/
*.pyc
.conda/

# OS noise
.DS_Store

# Keep placeholder docs if present
!data/raw/README.md
!data/reference/README.md
!data/db/README.md
!results/README.md

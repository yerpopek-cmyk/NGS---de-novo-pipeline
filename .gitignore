# =============================================================================
# .gitignore — de novo assembly course repository
# =============================================================================
# Files listed here will NOT be tracked by git.
# This prevents accidentally committing gigabytes of raw sequencing data.

# --- Raw sequencing data ---
*.fastq
*.fq
*.fastq.gz
*.fq.gz
*.sra

# --- Alignment files ---
*.bam
*.bam.bai
*.sam
*.cram
*.crai

# --- BWA index files (auto-generated, no need to store) ---
*.bwt
*.pac
*.sa
*.amb
*.ann

# --- Large genome files ---
*.fasta.gz
*.fa.gz

# --- Data and results directories (regenerated by the scripts) ---
data/raw/
data/db/
data/reference/
results/

# --- SPAdes intermediate files ---
K*/
corrected/
misc/
pipeline_state/

# --- Temp / log files ---
*.tmp
*.log
tmp/
temp/

# --- Python / conda ---
__pycache__/
*.pyc
.conda/

# --- macOS ---
.DS_Store

# =============================================================================
# EXCEPTIONS — always track these even if their parent folder is ignored
# =============================================================================
!data/raw/README.md
!data/reference/README.md
!data/db/README.md
